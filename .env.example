# SHC Backend — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ── Firebase browser config (public — safe to expose in frontend) ───────────────
# Find all 6 values in: Firebase Console → Project Settings → General → Your apps → SDK setup
FIREBASE_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# ── Server-only secrets (never expose in browser JS) ────────────────────────────
# Firebase Functions config — set via: firebase functions:config:set
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ── Email notifications ──────────────────────────────────────────────────────────
# API key from your transactional email provider (Resend, SendGrid, Postmark, etc.)
EMAIL_PROVIDER_API_KEY=

# Staff inbox that receives inquiry and access-request notifications
NOTIFICATION_EMAIL=info@southernhabitatconsulting.com

# Verified sender address for outgoing notifications
EMAIL_FROM=noreply@southernhabitatconsulting.com

# ── Site URLs ─────────────────────────────────────────────────────────────────────
PUBLIC_SITE_URL=https://southernhabitatconsulting.com
