# SHC Backend — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL from: Supabase dashboard → Settings → API
SUPABASE_URL=

# Anon (public) key — safe for browser JS (protected by RLS)
# From: Supabase dashboard → Settings → API → Project API keys → anon public
SUPABASE_ANON_KEY=

# Service role key — NEVER put this in browser JavaScript
# Used only in Edge Functions and server-side scripts
# From: Supabase dashboard → Settings → API → Project API keys → service_role secret
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret — used to verify tokens server-side
# From: Supabase dashboard → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=

# ── Site URLs ─────────────────────────────────────────────────────────────────
# Production domain for the public website (no trailing slash)
PUBLIC_SITE_URL=https://southernhabitatconsulting.com

# Portal URL (no trailing slash) — may be same domain or subdomain
PORTAL_SITE_URL=https://southernhabitatconsulting.com

# ── Email notifications ───────────────────────────────────────────────────────
# Verified sender address for outgoing staff notifications
NOTIFICATION_EMAIL_FROM=noreply@southernhabitatconsulting.com

# Staff inbox that receives inquiry and access-request notifications
NOTIFICATION_EMAIL_TO=info@southernhabitatconsulting.com

# API key for your email provider (Resend, Postmark, SendGrid, etc.)
EMAIL_PROVIDER_API_KEY=

# ── ArcGIS (optional — required only if private secured maps are used) ────────
# OAuth credentials from ArcGIS Online / Enterprise for token exchange
# Leave blank if only public embed URLs are used
ARCGIS_CLIENT_ID=
ARCGIS_CLIENT_SECRET=
ARCGIS_PORTAL_URL=https://www.arcgis.com
