rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Auth helpers ────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function role() {
      return request.auth.token.get('role', '');
    }

    function clientIds() {
      return request.auth.token.get('clientIds', []);
    }

    function isSuperAdmin() {
      return role() == 'super_admin';
    }

    function isAdmin() {
      return role() in ['super_admin', 'staff_admin'];
    }

    function isStaff() {
      return role() in ['super_admin', 'staff_admin', 'field_staff'];
    }

    function isClient() {
      return role() in ['client_owner', 'client_viewer'];
    }

    function isClientOwner() {
      return role() == 'client_owner';
    }

    // ── Client access helpers ────────────────────────────────────────────────
    function clientCanAccess(clientId) {
      return isAuthenticated()
        && isClient()
        && clientId is string
        && clientId in clientIds();
    }

    function hasClientId(data) {
      return data.keys().hasAny(['clientId']);
    }

    function hasPropertyId(data) {
      return data.keys().hasAny(['propertyId']);
    }

    function hasBudgetId(data) {
      return data.keys().hasAny(['budgetId']);
    }

    function hasMessageId(data) {
      return data.keys().hasAny(['messageId']);
    }

    function propertyClientId(propertyId) {
      return get(/databases/$(database)/documents/properties/$(propertyId)).data.clientId;
    }

    function budgetClientId(budgetId) {
      return get(/databases/$(database)/documents/budgets/$(budgetId)).data.clientId;
    }

    function messageClientId(messageId) {
      return get(/databases/$(database)/documents/messages/$(messageId)).data.clientId;
    }

    function clientCanAccessProperty(propertyId) {
      return isAuthenticated()
        && isClient()
        && propertyId is string
        && propertyClientId(propertyId) in clientIds();
    }

    function clientCanAccessBudget(budgetId) {
      return isAuthenticated()
        && isClient()
        && budgetId is string
        && budgetClientId(budgetId) in clientIds();
    }

    function clientCanAccessMessage(messageId) {
      return isAuthenticated()
        && isClient()
        && messageId is string
        && messageClientId(messageId) in clientIds();
    }

    function clientCanAccessRecord(data) {
      return (
          hasClientId(data)
          && clientCanAccess(data.clientId)
        )
        || (
          hasPropertyId(data)
          && clientCanAccessProperty(data.propertyId)
        )
        || (
          hasBudgetId(data)
          && clientCanAccessBudget(data.budgetId)
        )
        || (
          hasMessageId(data)
          && clientCanAccessMessage(data.messageId)
        );
    }

    function isClientVisible(data) {
      return data.keys().hasAny(['clientVisible'])
        && data.clientVisible == true;
    }

    function clientCanReadVisibleRecord(data) {
      return isAuthenticated()
        && isClient()
        && isClientVisible(data)
        && clientCanAccessRecord(data);
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated() && (uid() == userId || isStaff());
      allow write: if isAdmin();
    }

    // ── Clients ──────────────────────────────────────────────────────────────
    match /clients/{clientId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || clientCanAccess(clientId)
        );

      allow write: if isAdmin();
    }

    match /clientsInternal/{clientId} {
      allow read, write: if isStaff();
    }

    // ── Client Users ─────────────────────────────────────────────────────────
    match /clientUsers/{docId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || clientCanAccessRecord(resource.data)
          || uid() == resource.data.userId
        );

      allow write: if isAdmin();
    }

    // ── Properties ───────────────────────────────────────────────────────────
    match /properties/{propertyId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || clientCanAccess(resource.data.clientId)
        );

      allow write: if isAdmin();
    }

    match /propertiesInternal/{propertyId} {
      allow read, write: if isStaff();
    }

    // ── Property Sections / My Property tab ──────────────────────────────────
    match /propertySections/{sectionId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || clientCanReadVisibleRecord(resource.data)
          || clientCanAccessRecord(resource.data)
        );

      allow write: if isStaff();
    }

    match /propertySectionsInternal/{sectionId} {
      allow read, write: if isStaff();
    }

    // ── Projects / Overview + Work & Projects tabs ──────────────────────────
    match /projects/{projectId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || clientCanReadVisibleRecord(resource.data)
        );

      allow write: if isStaff();
    }

    match /projectsInternal/{projectId} {
      allow read, write: if isStaff();
    }

    // ── Project Actions / client responses ──────────────────────────────────
    match /projectActions/{actionId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || clientCanAccessRecord(resource.data)
        );

      allow create: if isAuthenticated()
        && isClient()
        && clientCanAccess(request.resource.data.clientId)
        && request.resource.data.userId == uid();

      allow update, delete: if isAdmin();
    }

    // ── Work History / Overview + Work & Projects tabs ──────────────────────
    match /workHistory/{workId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || clientCanReadVisibleRecord(resource.data)
        );

      allow write: if isStaff();
    }

    // ── Monitoring Records ───────────────────────────────────────────────────
    match /monitoringRecords/{recordId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || clientCanReadVisibleRecord(resource.data)
        );

      allow write: if isStaff();
    }

    // ── Wildlife Analysis tab ────────────────────────────────────────────────
    match /wildlifeSurveys/{surveyId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || clientCanReadVisibleRecord(resource.data)
        );

      allow write: if isStaff();
    }

    match /harvestRecords/{recordId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || clientCanReadVisibleRecord(resource.data)
        );

      allow write: if isStaff();
    }

    // ── Plan & Budget tab ────────────────────────────────────────────────────
    match /budgets/{budgetId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || clientCanReadVisibleRecord(resource.data)
        );

      allow write: if isAdmin();
    }

    match /budgetItems/{itemId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || clientCanReadVisibleRecord(resource.data)
          || clientCanAccessRecord(resource.data)
        );

      allow write: if isAdmin();
    }

    // ── Reports & Files tab ──────────────────────────────────────────────────
    match /documents/{docId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || (
            resource.data.documentStatus == 'published'
            && clientCanReadVisibleRecord(resource.data)
          )
        );

      allow write: if isAdmin();
    }

    match /documentsInternal/{docId} {
      allow read, write: if isStaff();
    }

    // ── Photographs ──────────────────────────────────────────────────────────
    match /photographs/{photoId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || clientCanReadVisibleRecord(resource.data)
        );

      allow write: if isStaff();
    }

    // ── Property Map tab ─────────────────────────────────────────────────────
    match /arcgisMaps/{mapId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || (
            resource.data.active == true
            && clientCanReadVisibleRecord(resource.data)
          )
        );

      allow write: if isAdmin();
    }

    match /mapFiles/{fileId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || clientCanReadVisibleRecord(resource.data)
          || clientCanAccessRecord(resource.data)
        );

      allow write: if isStaff();
    }

    // ── Messages tab ─────────────────────────────────────────────────────────
    match /messages/{messageId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || clientCanReadVisibleRecord(resource.data)
        );

      allow create: if isAuthenticated()
        && isClient()
        && request.resource.data.clientVisible == true
        && clientCanAccess(request.resource.data.clientId);

      allow update: if isAuthenticated()
        && (
          isStaff()
          || clientCanAccessRecord(resource.data)
        );

      allow delete: if isAdmin();
    }

    match /messageEntries/{entryId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || (
            resource.data.internalOnly == false
            && clientCanAccessRecord(resource.data)
          )
        );

      allow create: if isAuthenticated()
        && (
          isStaff()
          || (
            isClient()
            && request.resource.data.internalOnly == false
            && request.resource.data.senderId == uid()
            && clientCanAccess(request.resource.data.clientId)
          )
        );

      allow update, delete: if isAdmin();
    }

    // ── Website Inquiries ────────────────────────────────────────────────────
    match /inquiries/{inquiryId} {
      allow read, write: if isStaff();
    }

    // ── Access Requests ──────────────────────────────────────────────────────
    match /accessRequests/{requestId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ── Notifications ────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || uid() == resource.data.userId
        );

      allow update: if isAuthenticated()
        && uid() == resource.data.userId;

      allow create, delete: if isAdmin();
    }

    // ── Audit Logs ───────────────────────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read: if isStaff();
      allow write: if false;
    }

    // ── System Settings ──────────────────────────────────────────────────────
    match /systemSettings/{settingId} {
      allow read, write: if isSuperAdmin();
    }

    // ── Internal rate-limit counters ─────────────────────────────────────────
    match /_rateLimit/{docId} {
      allow read, write: if false;
    }

    // ── Default deny ─────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
