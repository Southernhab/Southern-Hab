rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function role() {
      return request.auth.token.get('role', '');
    }

    function clientIds() {
      return request.auth.token.get('clientIds', []);
    }

    function isSuperAdmin() {
      return role() == 'super_admin';
    }

    function isAdmin() {
      return role() in ['super_admin', 'staff_admin'];
    }

    function isStaff() {
      return role() in ['super_admin', 'staff_admin', 'field_staff'];
    }

    function isClient() {
      return role() in ['client_owner', 'client_viewer'];
    }

    function isClientOwner() {
      return role() == 'client_owner';
    }

    function clientCanAccess(clientId) {
      return isAuthenticated()
        && isClient()
        && clientId in clientIds();
    }

    function propertyClientId(propertyId) {
      return get(/databases/$(database)/documents/properties/$(propertyId)).data.clientId;
    }

    function clientCanAccessProperty(propertyId) {
      return isAuthenticated()
        && isClient()
        && propertyId is string
        && propertyClientId(propertyId) in clientIds();
    }

    function clientCanAccessResource() {
      return clientCanAccess(resource.data.clientId)
        || clientCanAccessProperty(resource.data.propertyId);
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated() && (uid() == userId || isStaff());
      allow write: if isAdmin();
    }

    // ── Clients ──────────────────────────────────────────────────────────────
    match /clients/{clientId} {
      allow read: if isAuthenticated() && (isStaff() || clientCanAccess(clientId));
      allow write: if isAdmin();
    }

    match /clientsInternal/{clientId} {
      allow read, write: if isStaff();
    }

    // ── Client Users ─────────────────────────────────────────────────────────
    match /clientUsers/{docId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || clientCanAccess(resource.data.clientId)
        );
      allow write: if isAdmin();
    }

    // ── Properties ───────────────────────────────────────────────────────────
    match /properties/{propertyId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || clientCanAccess(resource.data.clientId)
        );
      allow write: if isAdmin();
    }

    match /propertiesInternal/{propertyId} {
      allow read, write: if isStaff();
    }

    // ── Property Sections ────────────────────────────────────────────────────
    match /propertySections/{sectionId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || clientCanAccessResource()
        );
      allow write: if isStaff();
    }

    match /propertySectionsInternal/{sectionId} {
      allow read, write: if isStaff();
    }

    // ── Projects ─────────────────────────────────────────────────────────────
    match /projects/{projectId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || (
            resource.data.clientVisible == true
            && clientCanAccessResource()
          )
        );
      allow write: if isStaff();
    }

    match /projectsInternal/{projectId} {
      allow read, write: if isStaff();
    }

    // ── Project Actions ──────────────────────────────────────────────────────
    match /projectActions/{actionId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || clientCanAccessResource()
        );

      allow create: if isAuthenticated()
        && isClient()
        && clientCanAccess(request.resource.data.clientId)
        && request.resource.data.clientUserId == uid();

      allow update, delete: if isAdmin();
    }

    // ── Work History ─────────────────────────────────────────────────────────
    match /workHistory/{workId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || (
            resource.data.clientVisible == true
            && clientCanAccessResource()
          )
        );
      allow write: if isStaff();
    }

    // ── Monitoring Records ───────────────────────────────────────────────────
    match /monitoringRecords/{recordId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || (
            resource.data.clientVisible == true
            && clientCanAccessResource()
          )
        );
      allow write: if isStaff();
    }

    // ── Wildlife Surveys ─────────────────────────────────────────────────────
    match /wildlifeSurveys/{surveyId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || (
            resource.data.clientVisible == true
            && clientCanAccessResource()
          )
        );
      allow write: if isStaff();
    }

    // ── Harvest Records ──────────────────────────────────────────────────────
    match /harvestRecords/{recordId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || (
            resource.data.clientVisible == true
            && clientCanAccessResource()
          )
        );
      allow write: if isStaff();
    }

    // ── Budgets ──────────────────────────────────────────────────────────────
    match /budgets/{budgetId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || (
            resource.data.clientVisible == true
            && clientCanAccessResource()
          )
        );
      allow write: if isAdmin();
    }

    match /budgetItems/{itemId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || clientCanAccess(resource.data.clientId)
          || clientCanAccessProperty(resource.data.propertyId)
        );
      allow write: if isAdmin();
    }

    // ── Documents ────────────────────────────────────────────────────────────
    match /documents/{docId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || (
            resource.data.clientVisible == true
            && resource.data.documentStatus == 'published'
            && clientCanAccessResource()
          )
        );
      allow write: if isAdmin();
    }

    match /documentsInternal/{docId} {
      allow read, write: if isStaff();
    }

    // ── Photographs ──────────────────────────────────────────────────────────
    match /photographs/{photoId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || (
            resource.data.clientVisible == true
            && clientCanAccessResource()
          )
        );
      allow write: if isStaff();
    }

    // ── ArcGIS Maps ──────────────────────────────────────────────────────────
    match /arcgisMaps/{mapId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || (
            resource.data.clientVisible == true
            && resource.data.active == true
            && clientCanAccessResource()
          )
        );
      allow write: if isAdmin();
    }

    // ── Map Files ────────────────────────────────────────────────────────────
    match /mapFiles/{fileId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || clientCanAccessResource()
        );
      allow write: if isStaff();
    }

    // ── Messages ─────────────────────────────────────────────────────────────
    match /messages/{messageId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || (
            resource.data.clientVisible == true
            && clientCanAccessResource()
          )
        );

      allow create: if isAuthenticated()
        && isClient()
        && clientCanAccess(request.resource.data.clientId)
        && request.resource.data.clientVisible == true;

      allow update: if isAuthenticated()
        && (
          isStaff()
          || clientCanAccessResource()
        );

      allow delete: if isAdmin();
    }

    match /messageEntries/{entryId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || (
            resource.data.internalOnly == false
            && clientCanAccess(resource.data.clientId)
          )
        );

      allow create: if isAuthenticated()
        && (
          isStaff()
          || (
            isClient()
            && clientCanAccess(request.resource.data.clientId)
            && request.resource.data.internalOnly == false
            && request.resource.data.senderId == uid()
          )
        );

      allow update, delete: if isAdmin();
    }

    // ── Inquiries ────────────────────────────────────────────────────────────
    match /inquiries/{inquiryId} {
      allow read, write: if isStaff();
    }

    // ── Access Requests ──────────────────────────────────────────────────────
    match /accessRequests/{requestId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // ── Notifications ────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuthenticated()
        && (
          isStaff()
          || uid() == resource.data.userId
        );

      allow update: if isAuthenticated()
        && uid() == resource.data.userId;

      allow create, delete: if isAdmin();
    }

    // ── Audit Logs ───────────────────────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read: if isStaff();
      allow write: if false;
    }

    // ── System Settings ──────────────────────────────────────────────────────
    match /systemSettings/{settingId} {
      allow read, write: if isSuperAdmin();
    }

    // ── Internal rate-limit counters ─────────────────────────────────────────
    match /_rateLimit/{docId} {
      allow read, write: if false;
    }

    // ── Catch-all ────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
