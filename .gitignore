# SHC — gitignore

# ── Environment secrets (NEVER commit these) ──────────────────────────────────
.env
.env.local
.env.production

# ── Supabase browser config (generated by netlify build or created locally) ───
portal/config.js
admin/config.js

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*

# ── Supabase CLI ──────────────────────────────────────────────────────────────
supabase/.temp/
.supabase/

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/settings.json
