# SHC — gitignore

# ── Environment secrets (NEVER commit these) ──────────────────────────────────
.env
.env.local
.env.production

# ── Firebase browser config (generated by netlify build or created locally) ───
portal/firebase-config.js
admin/firebase-config.js

# ── Firebase CLI ──────────────────────────────────────────────────────────────
.firebaserc
firebase-debug.log
.firebase/

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
functions/node_modules/

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/settings.json
